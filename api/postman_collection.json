{
  "info": {
    "name": "API Gestión Médica - Proyecto Reto",
    "description": "Colección completa de endpoints para el sistema de gestión médica.\n\n**Autenticación:** Header `X-API-Key: demo-key-2026`\n**Base URL:** http://localhost:3000\n\nIncluye ejemplos correctos e incorrectos para cada recurso.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "apiKey", "value": "demo-key-2026" }
  ],
  "auth": {
    "type": "apikey",
    "apikey": [
      { "key": "key", "value": "X-API-Key", "type": "string" },
      { "key": "value", "value": "{{apiKey}}", "type": "string" },
      { "key": "in", "value": "header", "type": "string" }
    ]
  },
  "item": [
    {
      "name": "Pacientes",
      "item": [
        {
          "name": "GET Listar pacientes",
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));", "pm.test('Respuesta es array', () => pm.expect(pm.response.json()).to.be.an('array'));"], "type": "text/javascript" } }],
          "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/api/pacientes", "host": ["{{baseUrl}}"], "path": ["api", "pacientes"] } }
        },
        {
          "name": "GET Pacientes por apellido",
          "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/api/pacientes?apellido=Pérez", "host": ["{{baseUrl}}"], "path": ["api", "pacientes"], "query": [{ "key": "apellido", "value": "Pérez" }] } }
        },
        {
          "name": "GET Paciente por ID",
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));", "pm.test('Tiene historia_clinica', () => pm.response.to.have.jsonBody('HISTORIA_CLINICA'));"], "type": "text/javascript" } }],
          "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/api/pacientes/16", "host": ["{{baseUrl}}"], "path": ["api", "pacientes", "16"] } }
        },
        {
          "name": "GET Paciente inexistente (incorrecto)",
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 404', () => pm.response.to.have.status(404));"], "type": "text/javascript" } }],
          "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/api/pacientes/99999", "host": ["{{baseUrl}}"], "path": ["api", "pacientes", "99999"] } }
        },
        {
          "name": "POST Crear paciente",
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 201', () => pm.response.to.have.status(201));"], "type": "text/javascript" } }],
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/api/pacientes", "host": ["{{baseUrl}}"], "path": ["api", "pacientes"] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"cedula\": \"0102999999\",\n  \"nombres\": \"Juan Carlos\",\n  \"apellidos\": \"Test Creacion\",\n  \"fecha_nacimiento\": \"1995-06-15\",\n  \"sexo\": \"M\",\n  \"email\": \"test.creacion@mail.com\",\n  \"historia_clinica\": \"HC-TEST-CREATE\"\n}" }
          }
        },
        {
          "name": "POST Crear paciente sin campos requeridos (incorrecto)",
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 4xx o 5xx', () => pm.response.code >= 400);"], "type": "text/javascript" } }],
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/api/pacientes", "host": ["{{baseUrl}}"], "path": ["api", "pacientes"] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"nombres\": \"Sin Datos\"\n}" }
          }
        },
        {
          "name": "PUT Actualizar paciente",
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"], "type": "text/javascript" } }],
          "request": {
            "method": "PUT",
            "url": { "raw": "{{baseUrl}}/api/pacientes/16", "host": ["{{baseUrl}}"], "path": ["api", "pacientes", "16"] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"cedula\": \"0102000016\",\n  \"nombres\": \"Ana Lucía\",\n  \"apellidos\": \"Pérez Mosquera\",\n  \"fecha_nacimiento\": \"1990-04-12\",\n  \"sexo\": \"F\",\n  \"email\": \"ana.perez@mail.com\",\n  \"tipo_sangre\": \"A\",\n  \"factor_rh\": \"+\",\n  \"ocupacion\": \"Estudiante\",\n  \"estado_civil\": \"SOLTERO\"\n}" }
          }
        },
        {
          "name": "DELETE Eliminar paciente",
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"], "type": "text/javascript" } }],
          "request": { "method": "DELETE", "url": { "raw": "{{baseUrl}}/api/pacientes/99999", "host": ["{{baseUrl}}"], "path": ["api", "pacientes", "99999"] } }
        },
        {
          "name": "DELETE Eliminar paciente inexistente (incorrecto)",
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 200 o 404', () => pm.response.code >= 200 && pm.response.code < 500);"], "type": "text/javascript" } }],
          "request": { "method": "DELETE", "url": { "raw": "{{baseUrl}}/api/pacientes/99999", "host": ["{{baseUrl}}"], "path": ["api", "pacientes", "99999"] } }
        }
      ]
    },
